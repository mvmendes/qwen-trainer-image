# AlienX QLoRA training — Vast.ai base image (CUDA 13.3) + Qwen 7B pre-cached
#
# Build:  docker build --platform linux/amd64 -t ghcr.io/mvmendes/alienx-train:3.0-vast .
# Push:   docker push ghcr.io/mvmendes/alienx-train:3.0-vast
#
# Usar na Vast.ai: Container Image = ghcr.io/mvmendes/alienx-train:3.0-vast
#
# Vantagens sobre RunPod:
#   - CUDA 13.3 (mais recente)
#   - SSH nativo Vast.ai (não precisa de template)
#   - Modelo Qwen 7B pré-cacheado (zero download em Pod novo)

FROM vastai/base-image:cuda-13.3.0-auto

ENV DEBIAN_FRONTEND=noninteractive \
    HF_HOME=/workspace/hf_cache \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
    PYTHONUNBUFFERED=1

# Python 3.12 (ja vem na imagem com Ubuntu 24.04) — Unsloth suporta 3.11-3.13
RUN apt-get update -qq && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq --no-install-recommends \
      python3-pip python3-venv screen wget unzip && \
    rm -rf /var/lib/apt/lists/* && \
    python3 -m pip install -U pip --break-system-packages && \
    python3 --version

# PyTorch 2.8+ cu128 (Blackwell)
RUN pip install torch==2.8.0 torchvision==0.23.0 torchaudio==2.8.0 \
    --index-url https://download.pytorch.org/whl/cu128 --break-system-packages

# Unsloth (commit fixo)
ARG UNSLOTH_COMMIT=1fcd69e662f233896e075fc03472f45ac60e8819
RUN pip install "unsloth[colab-new] @ git+https://github.com/unslothai/unsloth.git@${UNSLOTH_COMMIT}" --break-system-packages

# Triton 3.3.1+ (Blackwell) + bitsandbytes 0.45.3+
RUN pip install -U "triton>=3.3.1" "bitsandbytes>=0.45.3" --break-system-packages

# Flash Attention 2 (necessario na Blackwell — sem xformers)
RUN pip install flash-attn --no-build-isolation --break-system-packages

# torchao quebra — remover
RUN pip uninstall -y torchao --break-system-packages || true

# Pre-cache Qwen 2.5 Coder 7B (evita download em todo Pod novo)
RUN python3 -c "from huggingface_hub import snapshot_download; \
    snapshot_download('Qwen/Qwen2.5-Coder-7B-Instruct')"

# Sanidade (sem import unsloth — exige GPU)
RUN python3 -c "import torch, transformers, trl, peft, bitsandbytes, flash_attn; \
    print('torch', torch.__version__, '| transformers', transformers.__version__, \
    '| trl', trl.__version__, '| flash-attn', flash_attn.__version__, \
    '| CUDA ok:', torch.cuda.is_available())"

WORKDIR /workspace
