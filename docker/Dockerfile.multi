# AlienX QLoRA training image — MULTI-GPU (parametrizavel)
#
# Build para RTX 3090/4090/L4 (padrao):
#   docker build --platform linux/amd64 \
#     -t SEU_USUARIO/qwen-trainer-image:1.0 \
#     -f docker/Dockerfile.multi docker/
#
# Build para RTX 5090 (Blackwell):
#   docker build --platform linux/amd64 \
#     --build-arg GPU_ARCH=blackwell \
#     -t SEU_USUARIO/qwen-trainer-image:2.0-blackwell \
#     -f docker/Dockerfile.multi docker/
#
# Tags:
#   :1.0            -> RTX 3090, RTX 4090, L4, T4 (CUDA 12.4, torch 2.6)
#   :2.0-blackwell  -> RTX 5090 (CUDA 12.8, torch 2.8)

ARG GPU_ARCH=legacy

# ==========================================================================
# Base images por GPU_ARCH
# ==========================================================================
FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04 AS base-legacy
FROM runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404 AS base-blackwell
FROM base-${GPU_ARCH} AS final

ARG GPU_ARCH=legacy
ARG UNSLOTH_COMMIT=1fcd69e662f233896e075fc03472f45ac60e8819

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
    PYTHONUNBUFFERED=1

# ==========================================================================
# Unsloth (commit fixo)
# ==========================================================================
RUN pip install -U pip && \
    pip install "unsloth[colab-new] @ git+https://github.com/unslothai/unsloth.git@${UNSLOTH_COMMIT}"

# ==========================================================================
# Blackwell extras: Triton 3.3.1+, bitsandbytes 0.45.3+
# A base ja tem torch 2.8+cu128 e xformers compativel — nao sobrepor.
# ==========================================================================
RUN if [ "$GPU_ARCH" = "blackwell" ]; then \
      pip install -U "triton>=3.3.1" "bitsandbytes>=0.45.3"; \
    fi

# ==========================================================================
# Legacy: fixa torch 2.6 + cu124 + xformers 0.0.29.post3
# ==========================================================================
RUN if [ "$GPU_ARCH" != "blackwell" ]; then \
      pip install -U torch==2.6.0 torchvision==0.21.0 torchaudio==2.6.0 \
        --index-url https://download.pytorch.org/whl/cu124 && \
      pip install --no-deps xformers==0.0.29.post3; \
    fi

# ==========================================================================
# Limpeza
# ==========================================================================
RUN pip uninstall -y torchao || true

# ==========================================================================
# Sanidade em build-time (sem import unsloth — exige GPU, ausente no runner)
# Blackwell: xformers nao vem na base, instala-se em runtime no pod com GPU.
# ==========================================================================
RUN if [ "$GPU_ARCH" = "blackwell" ]; then \
      python -c "import torch, transformers, trl, peft, bitsandbytes; \
print('GPU_ARCH=blackwell | torch', torch.__version__, \
'| transformers', transformers.__version__, '| trl', trl.__version__)"; \
    else \
      python -c "import torch, transformers, trl, peft, bitsandbytes, xformers; \
print('GPU_ARCH=legacy | torch', torch.__version__, \
'| transformers', transformers.__version__, '| trl', trl.__version__, \
'| xformers', xformers.__version__)"; \
    fi

WORKDIR /workspace
